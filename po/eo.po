#: src/getbar.c:829
#, c-format
msgid "%s: wrote chart %s\n"
msgstr "%s: skribis diagramon %s\n"

#: src/getbar.c:845
#, c-format
msgid "%s: wrote gnuplot script %s\n"
msgstr "%s: skribis gnuplot-skripton %s\n"

#: src/getbar.c:883
msgid ""
"Usage: getbar [OPTION]... URL\n"
"Download URL with HTTP(S) GET and record throughput bars.\n"
msgstr ""
"Uzo: getbar [OPCIO]... URL\n"
"Elŝutas URL per HTTP(S) GET kaj registri trafik-stangojn.\n"

#: src/getbar.c:888
msgid "split by received block size\n"
msgstr "dividi laŭ ricevita blokogrando\n"

#: src/getbar.c:890
msgid "split by time interval (NUM may be fractional)\n"
msgstr "dividi laŭ tempintervalo (NUM povas esti decimala)\n"

#: src/getbar.c:892
msgid "stop after receiving NUM bytes\n"
msgstr "halti post ricevo de NUM bajtoj\n"

#: src/getbar.c:894
msgid "stop after timeout\n"
msgstr "halti post tempolimo\n"

#: src/getbar.c:896
msgid "output offset and polynomial coeffs\n"
msgstr "eligi deklivon kaj polinomajn koeficientojn\n"

#: src/getbar.c:898
msgid "render chart (.png/.svg/.pdf/.eps) or save script\n"
msgstr "bildigi diagramon (.png/.svg/.pdf/.eps) aŭ konservi skripton\n"

#: src/getbar.c:900
msgid "overwrite gnuplot output file\n"
msgstr "anstataŭigi gnuplot-eligan dosieron\n"

#: src/getbar.c:902
msgid "output estimated bytes/sec after delay\n"
msgstr "eligi taksitajn bajtoj/s post prokrasto\n"

#: src/getbar.c:904
msgid "print summary after series: count size duration bps\n"
msgstr "presi resumon post serio: nombro grandeco daŭro bps\n"

#: src/getbar.c:906
msgid "omit pre-data wait from series, window, count; set -p offset\n"
msgstr "elizi antaŭ-datuman atendon el serio, fenestro, nombro; agordi -p-ofseton\n"

#: src/getbar.c:908
msgid "more logging to stderr\n"
msgstr "pli da protokolado al stderr\n"

#: src/getbar.c:910
msgid "omit the bar series on stdout\n"
msgstr "ne eligi stang-serion al stdout\n"

#: src/getbar.c:912
msgid "display this help and exit\n"
msgstr "montri cxi tiun helpon kaj eliri\n"

#: src/getbar.c:914
msgid "output version information and exit\n"
msgstr "montri versiajn informojn kaj eliri\n"

#: src/getbar.c:916
msgid ""
"Block mode (-b) prints per-block durations in microseconds. By default\n"
"the first value is the wait before data arrives. With -d that wait is\n"
"omitted from the series and derived metrics; -p then reports the delay\n"
"as offset. Interval mode (-i) includes leading zero intervals by default;\n"
"with -d they are omitted and -p offset is the idle time in seconds.\n"
"Polynomial, count, and estimate lines are printed after the series.\n"
"Optional theming: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"
msgstr ""
"Modo bloko (-b) presas daŭrojn po bloko en mikrosekundoj. Apriora la unua valoro estas la atendo antaŭ alveno de datumoj; kun -d tiu atendo estas elizita el la serio kaj derivitaj metrikoj; -p tiam raportas la prokraston kiel ofseton. Modo intervalo (-i) apriora inkluzivas intervalojn kun antaŭaj nuloj; kun -d ili estas elizitaj kaj -p-ofseto estas la neaktiva tempo en sekundoj.\n"
"Polinomaj, nombraj kaj estimaj linioj estas presitaj post la serio.\n"
"Laŭvola etoso: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"

#: src/getbar.c:924
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "Raportu cimojn al: <%s>\n"

