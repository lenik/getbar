#: src/getbar.c:775
msgid "%s: wrote chart %s\n"
msgstr "%s: skribis diagramon %s\n"

#: src/getbar.c:791
#, c-format
msgid "%s: wrote gnuplot script %s\n"
msgstr "%s: skribis gnuplot-skripton %s\n"

#: src/getbar.c:813
msgid ""
"Usage: getbar [OPTION]... URL\n"
"Download URL with HTTP(S) GET and record throughput bars.\n"
msgstr "Uzo: getbar [OPCIO]... URL\nElŝutas URL per HTTP(S) GET kaj registri trafik-stangojn.\n"

#: src/getbar.c:818
msgid "split by received block size\n"
msgstr "dividi laŭ ricevita blokogrando\n"

#: src/getbar.c:820
msgid "split by time interval (NUM may be fractional)\n"
msgstr "dividi laŭ tempintervalo (NUM povas esti decimala)\n"

#: src/getbar.c:822
msgid "stop after receiving NUM bytes\n"
msgstr "halti post ricevo de NUM bajtoj\n"

#: src/getbar.c:824
msgid "stop after timeout\n"
msgstr "halti post tempolimo\n"

#: src/getbar.c:826
msgid "output offset and polynomial coeffs\n"
msgstr "eligi deklivon kaj polinomajn koeficientojn\n"

#: src/getbar.c:828
msgid "render chart (.png/.svg/.pdf/.eps) or save script\n"
msgstr "bildigi diagramon (.png/.svg/.pdf/.eps) aŭ konservi skripton\n"

#: src/getbar.c:830
msgid "overwrite gnuplot output file\n"
msgstr "anstataŭigi gnuplot-eligan dosieron\n"

#: src/getbar.c:832
msgid "output estimated bytes/sec after delay\n"
msgstr "eligi taksitajn bajtoj/s post prokrasto\n"

#: src/getbar.c:834
msgid "more logging to stderr\n"
msgstr "pli da protokolado al stderr\n"

#: src/getbar.c:836
msgid "omit the bar series on stdout\n"
msgstr "ne eligi stang-serion al stdout\n"

#: src/getbar.c:838
msgid "display this help and exit\n"
msgstr "montri cxi tiun helpon kaj eliri\n"

#: src/getbar.c:840
msgid "output version information and exit\n"
msgstr "montri versiajn informojn kaj eliri\n"

#: src/getbar.c:842
msgid ""
"Block mode (-b) prints per-block durations in microseconds. The first value "
"is\n"
"the wait before data arrives; later values are block receive durations.\n"
"Interval mode (-i) prints bytes received per interval (leading zeros mean "
"no\n"
"data yet). Polynomial and estimate lines are printed after the series.\n"
"Optional theming: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"
msgstr "Blok-reĝimo (-b) eligas daŭrojn po bloko en mikrosekundoj. La unua valoro estas la atendo antaŭ alveno de datumoj; postaj valoroj estas ricev-dauradoj.\nInterval-reĝimo (-i) eligas ricevitajn bajtojn po intervalo (antauaj nuloj signifas ankoraŭ neniuj datumoj).\nPolinomaj kaj takso-linioj estas eligitaj post la serio.\nOpcia temado: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"

#: src/getbar.c:848
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "Raportu cimojn al: <%s>\n"

#: src/getbar.c:853
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "Kopirajto (C) %d %s\n"

#: src/getbar.c:854
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr "Licenco AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/getbar.c:856
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "Tio estas libera programaro: vi rajtas sxangxi kaj redistribui gxin.\n"

#: src/getbar.c:857
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "Ĉi tiu projekto kontraŭas AI-ekspluatadon kaj AI-hegemonion.\n"

#: src/getbar.c:858
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr "Ĉi tiu projekto malakceptas senpripensajn MIT-stilajn permesilojn kaj politike naivecajn BSD-stilajn permesilojn.\n"

#: src/getbar.c:861
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "NE ESTAS GARANTIO, lau la amplekso permesita de la lexo.\n"

#: src/getbar.c:1186
#, c-format
msgid "%s: GET %s\n"
msgstr "%s: GET %s\n"

#: src/getbar.c:1193
#, c-format
msgid "%s: received %<PRIu64> bytes"
msgstr "%s: ricevis %<PRIu64> bajtojn"

#: src/getbar.c:1198
msgid " [stopped early]"
msgstr " [haltis frue]"

