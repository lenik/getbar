#: src/getbar.c:775
msgid "%s: wrote chart %s\n"
msgstr "%s: grafico scritto %s\n"

#: src/getbar.c:791
#, c-format
msgid "%s: wrote gnuplot script %s\n"
msgstr "%s: script gnuplot scritto %s\n"

#: src/getbar.c:813
msgid ""
"Usage: getbar [OPTION]... URL\n"
"Download URL with HTTP(S) GET and record throughput bars.\n"
msgstr "Uso: getbar [OPZIONE]... URL\nScarica l'URL con HTTP(S) GET e registra barre di throughput.\n"

#: src/getbar.c:818
msgid "split by received block size\n"
msgstr "dividi per dimensione blocco ricevuto\n"

#: src/getbar.c:820
msgid "split by time interval (NUM may be fractional)\n"
msgstr "dividi per intervallo di tempo (NUM puo essere frazionario)\n"

#: src/getbar.c:822
msgid "stop after receiving NUM bytes\n"
msgstr "ferma dopo NUM byte ricevuti\n"

#: src/getbar.c:824
msgid "stop after timeout\n"
msgstr "ferma dopo timeout\n"

#: src/getbar.c:826
msgid "output offset and polynomial coeffs\n"
msgstr "restituisci offset e coefficienti polinomiali\n"

#: src/getbar.c:828
msgid "render chart (.png/.svg/.pdf/.eps) or save script\n"
msgstr "renderizza grafico (.png/.svg/.pdf/.eps) o salva script\n"

#: src/getbar.c:830
msgid "overwrite gnuplot output file\n"
msgstr "sovrascrivi file di output gnuplot\n"

#: src/getbar.c:832
msgid "output estimated bytes/sec after delay\n"
msgstr "restituisci byte/s stimati dopo ritardo\n"

#: src/getbar.c:834
msgid "more logging to stderr\n"
msgstr "piu log su stderr\n"

#: src/getbar.c:836
msgid "omit the bar series on stdout\n"
msgstr "ometti la serie di barre su stdout\n"

#: src/getbar.c:838
msgid "display this help and exit\n"
msgstr "mostra questo aiuto ed esce\n"

#: src/getbar.c:840
msgid "output version information and exit\n"
msgstr "mostra le informazioni di versione ed esce\n"

#: src/getbar.c:842
msgid ""
"Block mode (-b) prints per-block durations in microseconds. The first value "
"is\n"
"the wait before data arrives; later values are block receive durations.\n"
"Interval mode (-i) prints bytes received per interval (leading zeros mean "
"no\n"
"data yet). Polynomial and estimate lines are printed after the series.\n"
"Optional theming: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"
msgstr "La modalita blocco (-b) stampa durate per blocco in microsecondi. Il primo valore e l'attesa prima dell'arrivo dei dati; i successivi sono durate di ricezione.\nLa modalita intervallo (-i) stampa byte ricevuti per intervallo (zeri iniziali significano ancora nessun dato).\nLe righe polinomiale e di stima vengono stampate dopo la serie.\nTema opzionale: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"

#: src/getbar.c:848
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "Segnala bug a: <%s>\n"

