#: src/getbar.c:775
msgid "%s: wrote chart %s\n"
msgstr "%s: チャート %s を書き込みました\n"

#: src/getbar.c:791
#, c-format
msgid "%s: wrote gnuplot script %s\n"
msgstr "%s: gnuplot スクリプト %s を書き込みました\n"

#: src/getbar.c:813
msgid ""
"Usage: getbar [OPTION]... URL\n"
"Download URL with HTTP(S) GET and record throughput bars.\n"
msgstr "用法: getbar [オプション]... URL\nHTTP(S) GET で URL をダウンロードし、スループットの棒グラフ系列を記録します。\n"

#: src/getbar.c:818
msgid "split by received block size\n"
msgstr "受信ブロックサイズで分割\n"

#: src/getbar.c:820
msgid "split by time interval (NUM may be fractional)\n"
msgstr "時間間隔で分割（NUM は小数可）\n"

#: src/getbar.c:822
msgid "stop after receiving NUM bytes\n"
msgstr "NUM バイト受信後に停止\n"

#: src/getbar.c:824
msgid "stop after timeout\n"
msgstr "タイムアウト後に停止\n"

#: src/getbar.c:826
msgid "output offset and polynomial coeffs\n"
msgstr "オフセットと多項式係数を出力\n"

#: src/getbar.c:828
msgid "render chart (.png/.svg/.pdf/.eps) or save script\n"
msgstr "チャートを描画（.png/.svg/.pdf/.eps）またはスクリプトを保存\n"

#: src/getbar.c:830
msgid "overwrite gnuplot output file\n"
msgstr "gnuplot 出力ファイルを上書き\n"

#: src/getbar.c:832
msgid "output estimated bytes/sec after delay\n"
msgstr "遅延後に推定バイト/秒を出力\n"

#: src/getbar.c:834
msgid "more logging to stderr\n"
msgstr "stderr により多くのログを出力\n"

#: src/getbar.c:836
msgid "omit the bar series on stdout\n"
msgstr "stdout に棒系列を出力しない\n"

#: src/getbar.c:838
msgid "display this help and exit\n"
msgstr "このヘルプを表示して終了\n"

#: src/getbar.c:840
msgid "output version information and exit\n"
msgstr "バージョン情報を表示して終了\n"

#: src/getbar.c:842
msgid ""
"Block mode (-b) prints per-block durations in microseconds. The first value "
"is\n"
"the wait before data arrives; later values are block receive durations.\n"
"Interval mode (-i) prints bytes received per interval (leading zeros mean "
"no\n"
"data yet). Polynomial and estimate lines are printed after the series.\n"
"Optional theming: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"
msgstr "ブロックモード（-b）は各ブロックの受信時間（マイクロ秒）を出力します。最初の値はデータ到着前の待ち時間、以降は各ブロックの受信時間です。\n間隔モード（-i）は各間隔で受信したバイト数を出力します（先頭のゼロはまだデータがないことを意味します）。\n多項式と推定行は系列の後に出力されます。\n任意のテーマ: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"

#: src/getbar.c:848
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "不具合報告先: <%s>\n"

#: src/getbar.c:853
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "Copyright (C) %d %s\n"

#: src/getbar.c:854
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr ""
"ライセンス AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/getbar.c:856
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "これはフリーソフトウェアです。自由に改変および再配布できます。\n"

#: src/getbar.c:857
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "このプロジェクトは AI 搾取と AI 覇権に反対します。\n"

#: src/getbar.c:858
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr ""
"このプロジェクトは無批判な MIT 型ライセンスと政治的に愚かな BSD 型ライセンス"
"に反対します。\n"

#: src/getbar.c:861
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "法の許す範囲で一切の保証はありません。\n"

#: src/getbar.c:1186
#, c-format
msgid "%s: GET %s\n"
msgstr "%s: GET %s\n"

#: src/getbar.c:1193
#, c-format
msgid "%s: received %<PRIu64> bytes"
msgstr "%s: %<PRIu64> バイト受信"

#: src/getbar.c:1198
msgid " [stopped early]"
msgstr " [早期停止]"

