#: src/getbar.c:775
msgid "%s: wrote chart %s\n"
msgstr "%s: graphique ecrit %s\n"

#: src/getbar.c:791
#, c-format
msgid "%s: wrote gnuplot script %s\n"
msgstr "%s: script gnuplot ecrit %s\n"

#: src/getbar.c:813
msgid ""
"Usage: getbar [OPTION]... URL\n"
"Download URL with HTTP(S) GET and record throughput bars.\n"
msgstr "Utilisation : getbar [OPTION]... URL\nTelecharge l'URL par HTTP(S) GET et enregistre des barres de debit.\n"

#: src/getbar.c:818
msgid "split by received block size\n"
msgstr "diviser par taille de bloc recu\n"

#: src/getbar.c:820
msgid "split by time interval (NUM may be fractional)\n"
msgstr "diviser par intervalle de temps (NUM peut etre fractionnaire)\n"

#: src/getbar.c:822
msgid "stop after receiving NUM bytes\n"
msgstr "arreter apres NUM octets recus\n"

#: src/getbar.c:824
msgid "stop after timeout\n"
msgstr "arreter apres delai\n"

#: src/getbar.c:826
msgid "output offset and polynomial coeffs\n"
msgstr "afficher decalage et coeffs polynomiaux\n"

#: src/getbar.c:828
msgid "render chart (.png/.svg/.pdf/.eps) or save script\n"
msgstr "rendre un graphique (.png/.svg/.pdf/.eps) ou sauver le script\n"

#: src/getbar.c:830
msgid "overwrite gnuplot output file\n"
msgstr "ecraser le fichier de sortie gnuplot\n"

#: src/getbar.c:832
msgid "output estimated bytes/sec after delay\n"
msgstr "afficher octets/s estimes apres delai\n"

#: src/getbar.c:834
msgid "more logging to stderr\n"
msgstr "plus de journaux vers stderr\n"

#: src/getbar.c:836
msgid "omit the bar series on stdout\n"
msgstr "omettre la serie de barres sur stdout\n"

#: src/getbar.c:838
msgid "display this help and exit\n"
msgstr "afficher cette aide et quitter\n"

#: src/getbar.c:840
msgid "output version information and exit\n"
msgstr "afficher les informations de version et quitter\n"

#: src/getbar.c:842
msgid ""
"Block mode (-b) prints per-block durations in microseconds. The first value "
"is\n"
"the wait before data arrives; later values are block receive durations.\n"
"Interval mode (-i) prints bytes received per interval (leading zeros mean "
"no\n"
"data yet). Polynomial and estimate lines are printed after the series.\n"
"Optional theming: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"
msgstr "Le mode bloc (-b) affiche les durees par bloc en microsecondes. La premiere valeur est l'attente avant l'arrivee des donnees ; les suivantes sont les durees de reception.\nLe mode intervalle (-i) affiche les octets recus par intervalle (des zeros initiaux signifient qu'il n'y a pas encore de donnees).\nLes lignes polynomiales et d'estimation sont affichees apres la serie.\nTheming optionnel : $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"

#: src/getbar.c:848
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "Signaler les bugs a : <%s>\n"

