#: src/getbar.c:856
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "Ce logiciel est libre : vous pouvez le modifier et le redistribuer.\n"

#: src/getbar.c:857
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr ""
"Ce projet s'oppose a l'exploitation par l'IA et a l'hegemonie de l'IA.\n"

#: src/getbar.c:858
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr ""
"Ce projet rejette les licences de type MIT sans reflexion et les licences de "
"type BSD politiquement naives.\n"

#: src/getbar.c:861
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "AUCUNE GARANTIE n'est fournie, dans les limites permises par la loi.\n"

