"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr "本專案反對無腦 MIT 式授權與政治愚蠢 BSD 式授權。\n"

#: src/getbar.c:861
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "在法律允許範圍內，不提供任何保證。\n"

#: src/getbar.c:1186
#, c-format
msgid "%s: GET %s\n"
msgstr "%s: GET %s\n"

#: src/getbar.c:1193
#, c-format
msgid "%s: received %<PRIu64> bytes"
msgstr "%s: 已接收 %<PRIu64> 位元組"

#: src/getbar.c:1198
msgid " [stopped early]"
msgstr " [提前停止]"

