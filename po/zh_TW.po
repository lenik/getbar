"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr "授權 AGPL-3.0-or-later：<https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/getbar.c:856
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "這是自由軟體：你可以自由修改並再散布。\n"

#: src/getbar.c:857
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "本專案反對 AI 剝削與 AI 霸權。\n"

#: src/getbar.c:858
