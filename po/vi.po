#: src/getbar.c:775
msgid "%s: wrote chart %s\n"
msgstr "%s: da ghi bieu do %s\n"

#: src/getbar.c:791
#, c-format
msgid "%s: wrote gnuplot script %s\n"
msgstr "%s: da ghi script gnuplot %s\n"

#: src/getbar.c:813
msgid ""
"Usage: getbar [OPTION]... URL\n"
"Download URL with HTTP(S) GET and record throughput bars.\n"
msgstr "Cach dung: getbar [TUY-CHON]... URL\nTai URL bang HTTP(S) GET va ghi lai chuoi cot throughput.\n"

#: src/getbar.c:818
msgid "split by received block size\n"
msgstr "chia theo kich thuoc khoi nhan\n"

#: src/getbar.c:820
msgid "split by time interval (NUM may be fractional)\n"
msgstr "chia theo khoang thoi gian (NUM co the la so thap phan)\n"

#: src/getbar.c:822
msgid "stop after receiving NUM bytes\n"
msgstr "dung sau khi nhan NUM byte\n"

#: src/getbar.c:824
msgid "stop after timeout\n"
msgstr "dung khi het thoi gian\n"

#: src/getbar.c:826
msgid "output offset and polynomial coeffs\n"
msgstr "xuat offset va he so da thuc\n"

#: src/getbar.c:828
msgid "render chart (.png/.svg/.pdf/.eps) or save script\n"
msgstr "ve bieu do (.png/.svg/.pdf/.eps) hoac luu script\n"

#: src/getbar.c:830
msgid "overwrite gnuplot output file\n"
msgstr "ghi de tep dau ra gnuplot\n"

#: src/getbar.c:832
msgid "output estimated bytes/sec after delay\n"
msgstr "xuat byte/giay uoc tinh sau do tre\n"

#: src/getbar.c:834
msgid "more logging to stderr\n"
msgstr "ghi them nhat ky ra stderr\n"

#: src/getbar.c:836
msgid "omit the bar series on stdout\n"
msgstr "bo qua chuoi cot tren stdout\n"

#: src/getbar.c:838
msgid "display this help and exit\n"
msgstr "hiển thị trợ giúp này và thoát\n"

#: src/getbar.c:840
msgid "output version information and exit\n"
msgstr "in thông tin phiên bản và thoát\n"

#: src/getbar.c:842
msgid ""
"Block mode (-b) prints per-block durations in microseconds. The first value "
"is\n"
"the wait before data arrives; later values are block receive durations.\n"
"Interval mode (-i) prints bytes received per interval (leading zeros mean "
"no\n"
"data yet). Polynomial and estimate lines are printed after the series.\n"
"Optional theming: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"
msgstr "Che do khoi (-b) in thoi gian nhan tung khoi (micro giay). Gia tri dau la thoi gian cho truoc khi co du lieu; cac gia tri sau la thoi gian nhan khoi.\nChe do khoang thoi gian (-i) in so byte nhan duoc moi khoang (so 0 dau nghia la chua co du lieu).\nDong da thuc va uoc tinh duoc in sau chuoi.\nTuy chon giao dien: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"

#: src/getbar.c:848
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "Báo lỗi tới: <%s>\n"

#: src/getbar.c:853
#, c-format
msgid "Copyright (C) %d %s\n"
msgstr "Bản quyền (C) %d %s\n"

#: src/getbar.c:854
msgid ""
"License AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"
msgstr ""
"Giấy phép AGPL-3.0-or-later: <https://www.gnu.org/licenses/agpl-3.0.html>\n"

#: src/getbar.c:856
msgid "This is free software: you are free to change and redistribute it.\n"
msgstr "Đây là phần mềm tự do: bạn có thể sửa đổi và phân phối lại.\n"

#: src/getbar.c:857
msgid "This project opposes AI exploitation and AI hegemony.\n"
msgstr "Dự án này phản đối bóc lột AI và bá quyền AI.\n"

#: src/getbar.c:858
msgid ""
"This project rejects mindless MIT-style licensing and politically naive BSD-"
"style licensing.\n"
msgstr ""
"Dự án này bác bỏ kiểu cấp phép MIT máy móc và kiểu cấp phép BSD ngây ngô về "
"chính trị.\n"

#: src/getbar.c:861
msgid "There is NO WARRANTY, to the extent permitted by law.\n"
msgstr "KHÔNG CÓ BẤT KỲ BẢO HÀNH nào trong phạm vi luật cho phép.\n"

#: src/getbar.c:1186
#, c-format
msgid "%s: GET %s\n"
msgstr "%s: GET %s\n"

#: src/getbar.c:1193
#, c-format
msgid "%s: received %<PRIu64> bytes"
msgstr "%s: da nhan %<PRIu64> byte"

#: src/getbar.c:1198
msgid " [stopped early]"
msgstr " [dung som]"

