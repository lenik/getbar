#: src/getbar.c:775
msgid "%s: wrote chart %s\n"
msgstr "%s: Diagramm %s geschrieben\n"

#: src/getbar.c:791
#, c-format
msgid "%s: wrote gnuplot script %s\n"
msgstr "%s: gnuplot-Skript %s geschrieben\n"

#: src/getbar.c:813
msgid ""
"Usage: getbar [OPTION]... URL\n"
"Download URL with HTTP(S) GET and record throughput bars.\n"
msgstr "Verwendung: getbar [OPTION]... URL\nLaedt URL per HTTP(S)-GET herunter und zeichnet Durchsatzbalken auf.\n"

#: src/getbar.c:818
msgid "split by received block size\n"
msgstr "nach empfangener Blockgroesse aufteilen\n"

#: src/getbar.c:820
msgid "split by time interval (NUM may be fractional)\n"
msgstr "nach Zeitintervall aufteilen (NUM darf dezimal sein)\n"

#: src/getbar.c:822
msgid "stop after receiving NUM bytes\n"
msgstr "nach NUM empfangenen Bytes stoppen\n"

#: src/getbar.c:824
msgid "stop after timeout\n"
msgstr "nach Timeout stoppen\n"

#: src/getbar.c:826
msgid "output offset and polynomial coeffs\n"
msgstr "Offset und Polynomkoeffizienten ausgeben\n"

#: src/getbar.c:828
msgid "render chart (.png/.svg/.pdf/.eps) or save script\n"
msgstr "Diagramm rendern (.png/.svg/.pdf/.eps) oder Skript speichern\n"

#: src/getbar.c:830
msgid "overwrite gnuplot output file\n"
msgstr "gnuplot-Ausgabedatei ueberschreiben\n"

#: src/getbar.c:832
msgid "output estimated bytes/sec after delay\n"
msgstr "geschaetzte Bytes/s nach Verzoegerung ausgeben\n"

#: src/getbar.c:834
msgid "more logging to stderr\n"
msgstr "mehr Protokollausgabe nach stderr\n"

#: src/getbar.c:836
msgid "omit the bar series on stdout\n"
msgstr "Balkenreihe auf stdout weglassen\n"

#: src/getbar.c:838
msgid "display this help and exit\n"
msgstr "diese Hilfe anzeigen und beenden\n"

#: src/getbar.c:840
msgid "output version information and exit\n"
msgstr "Versionsinformationen anzeigen und beenden\n"

#: src/getbar.c:842
msgid ""
"Block mode (-b) prints per-block durations in microseconds. The first value "
"is\n"
"the wait before data arrives; later values are block receive durations.\n"
"Interval mode (-i) prints bytes received per interval (leading zeros mean "
"no\n"
"data yet). Polynomial and estimate lines are printed after the series.\n"
"Optional theming: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"
msgstr "Blockmodus (-b) gibt Dauer pro Block in Mikrosekunden aus. Der erste Wert ist die Wartezeit vor Datenankunft; danach folgen Empfangsdauern.\nIntervallmodus (-i) gibt empfangene Bytes pro Intervall aus (fuehrende Nullen bedeuten noch keine Daten).\nPolynom- und Schaetzwerte werden nach der Reihe ausgegeben.\nOptionales Theming: $XDG_CONFIG_HOME/getbar/gnuplot.rc\n"

#: src/getbar.c:848
#, c-format
msgid "Report bugs to: <%s>\n"
msgstr "Fehler melden an: <%s>\n"

